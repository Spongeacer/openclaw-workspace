# ============================================================
# YouTube 播客转中文语音合成系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值
# 优先级：环境变量 > .env 文件 > settings.yaml > 默认值
# ============================================================

# -----------------------------------------------------------------------------
# 核心配置
# -----------------------------------------------------------------------------

# 激活的 TTS 厂商 (stepfun | minimax)
ACTIVE_PROVIDER=stepfun

# 日志级别 (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# StepFun API 配置
# 文档: https://platform.stepfun.com/docs/overview
# -----------------------------------------------------------------------------

# StepFun API 密钥 (必填)
# 从 https://platform.stepfun.com/ 获取
STEPFUN_API_KEY=your_stepfun_api_key_here

# -----------------------------------------------------------------------------
# MiniMax API 配置
# 文档: https://www.minimaxi.com/document
# -----------------------------------------------------------------------------

# MiniMax API 密钥 (如需使用 MiniMax 时填写)
# 从 https://www.minimaxi.com/ 获取
MINIMAX_API_KEY=your_minimax_api_key_here

# -----------------------------------------------------------------------------
# Whisper 模型配置
# -----------------------------------------------------------------------------

# Whisper 模型存储目录
WHISPER_MODEL_DIR=./models

# 可选：手动指定 CUDA 设备 (如 "0", "0,1")
# CUDA_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# 代理配置（如需）
# -----------------------------------------------------------------------------

# HTTP 代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# -----------------------------------------------------------------------------
# 高级配置（通常不需要修改）
# -----------------------------------------------------------------------------

# 请求超时时间（秒）
# REQUEST_TIMEOUT=30

# 最大重试次数
# MAX_RETRIES=3

# 并发请求数限制
# MAX_CONCURRENT=5

# -----------------------------------------------------------------------------
# 输出配置（可被 settings.yaml 覆盖）
# -----------------------------------------------------------------------------

# 默认输出目录
# OUTPUT_DIR=./output

# 临时文件目录
# TEMP_DIR=./temp

# 是否保留中间文件 (true | false)
# KEEP_INTERMEDIATE=false
